---

const links = [
  { href: '/', label: 'Home' },
  { href: '/shows', label: 'Shows' },
  { href: '/weddings', label: 'Weddings' },
  { href: '/contact', label: 'Contact' },
];

---

<div class='nav-links'>
  {links.map(link =>
    <a
      href={link.href}
      class={`underline-hover ${Astro.url.pathname === link.href ? 'active' : ''}`}
    >{link.label}</a>
  )}
</div>

<style>
  .underline-hover {
    text-decoration: none;
    position: relative;
  }

  .underline-hover::after {
    content: '';
    position: absolute;
    width: 100%;
    height: 2px;
    background: currentColor;
    left: 0;
    bottom: -2px;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s ease;
  }

  .underline-hover:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  a {
    text-decoration: none;
  }

  a.active {
    text-decoration: underline;
  }
</style>